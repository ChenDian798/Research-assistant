OPENAI_API_KEY=
OPENAI_MODEL=
# Optional: use this for OpenAI-compatible providers.
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional per-node model overrides.
# INTENT_MODEL=
# RESEARCH_MODEL=
# SYNTHESIS_MODEL=

# Optional for DeepSeek V4. Use "enabled" for deeper reasoning, "disabled" for speed.
# DEEPSEEK_THINKING=disabled

# Optional deployment/runtime settings.
# WEB_HOST=0.0.0.0
# RESEARCH_AGENT_CONTACT_EMAIL=admin@example.com

# PDF extraction page budget. Use a number such as 120 or 200, or "all" for full-document extraction.
# PDF_EXTRACT_PAGE_LIMIT=120
# PDF parser mode: auto keeps the current pypdf/PyMuPDF path and tries OpenDataLoader only when extraction is sparse.
# Install opendataloader-pdf and Java 11+ before using PDF_PARSER=opendataloader.
# PDF_PARSER=auto
# PDF_OPENDATALOADER_MIN_CHARS=2000
# PDF_OPENDATALOADER_MIN_PAGE_RATIO=0.5

# Optional evidence packet optimizer before analyst extraction. Disable for maximum speed.
# LLM_EVIDENCE_REFINEMENT=enabled
# EVIDENCE_REFINEMENT_MODEL=

# Optional academic search integration.
PAPER_SEARCH_ENABLED=false
PAPER_SEARCH_COMMAND=paper-search
PAPER_SEARCH_DEFAULT_SOURCES=arxiv
PAPER_SEARCH_TIMEOUT_SECONDS=45
PAPER_SEARCH_MAX_RESULTS_PER_SOURCE=5
PAPER_SEARCH_MAX_TOTAL=40

# Optional topic-relevance gate. "rules" is fast and local; "medcpt" uses NCBI MedCPT if transformers/torch are available.
PAPER_RELEVANCE_RERANKER=rules
PAPER_RELEVANCE_MEDCPT_MODEL=ncbi/MedCPT-Cross-Encoder
PAPER_RELEVANCE_MEDCPT_MIN_SCORE=0.35

# Optional provider keys used by paper-search-mcp.
PAPER_SEARCH_MCP_SEMANTIC_SCHOLAR_API_KEY=
PAPER_SEARCH_MCP_CORE_API_KEY=
PAPER_SEARCH_MCP_UNPAYWALL_EMAIL=
